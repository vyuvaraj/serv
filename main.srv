// Setup Broker & Web Server
broker "in-memory"
server env("PORT")

// Map the Python extern analyzer script
extern fn analyzeText(text) from "python:./scripts/analyzer.py:analyze"

// Expose a REST API endpoint for checking status
route "GET" "/status" (req) {
    log.info("Status endpoint requested")
    metric.inc("status_requests_total")
    return { "status": "Serv is running", "timestamp": time.now() }
}

// Expose a webhook endpoint that publishes incoming messages
route "POST" "/webhook" (req) {
    let body = req.body
    log.info("Webhook received body: ", body)
    publish "webhook.events" body
    return { "received": true }
}

// Scheduled job running every 3 seconds
every 3s {
    log.info("Timer fired - publishing heartbeat")
    publish "heartbeat" "periodic-ping"
}

// Scheduled job running via cron expression loaded from env
cron env("BACKUP_CRON") {
    log.warn("Cron job triggered - performing simulated backup...")
    metric.inc("backups_run_total")
}

// Subscribe to heartbeat topic
subscribe "heartbeat" (msg) {
    log.info("Heartbeat subscription received: ", msg)
    metric.inc("heartbeats_received_total")
    
    // Concurrency: spawn worker task
    spawn handleHeartbeat(msg)
}

// Subscribe to webhook events topic
subscribe "webhook.events" (msg) {
    log.info("Event subscription received: ", msg)
    
    // Call Python extern library
    let analysis = analyzeText(msg)
    log.info("Result from Python analysis: ", analysis)
}

fn handleHeartbeat(payload) {
    log.info("Spawned concurrent worker for: ", payload)
    
    // Call our own hosted status API to test HTTP client natively!
    let selfStatus = http.get("http://localhost:8080/status")
    log.info("Self-healthcheck HTTP client response status: ", selfStatus.status)
    log.info("Self-healthcheck HTTP client response body: ", selfStatus.body)
}
