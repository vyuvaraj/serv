server "9000"

// Serve CSS, JS, and image assets from the ./public directory
html.static("/assets", "./public")

export route "GET" "/" (req) {
    let tpl = `<!DOCTYPE html>
<html>
<head>
    <title>Static File Test</title>
    <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
    <h1>html.static works!</h1>
    <img src="/assets/logo.png" alt="Logo">
    <script src="/assets/app.js"></script>
</body>
</html>`
    return html.template(tpl, {})
}
