import { newClient, createBucket, put, get, list, at, search, deleteObject, deleteBucket, setBucketVersioning } from "stdlib/s3.srv"

test "ServStore integration bucket and object lifecycle" {
    // 1. Initialize client pointing to local ServStore gateway
    let client = newClient("http://localhost:8080", "admin", "adminsecret")
    assert client != nil

    let bucket = nil
    bucket = "test-lang-" + time.unix()

    let vbucket = nil
    vbucket = bucket + "-ver"

    // 2. Create buckets
    assert createBucket(bucket) == "ok"
    assert createBucket(vbucket) == "ok"
    assert setBucketVersioning(vbucket, "Enabled") == "ok"

    // 3. Put document for semantic search indexing (.txt extension)
    let putDocRes = put(bucket, "consensus.txt", "This is an intelligence report on Raft consensus algorithms and distributed state replication.")
    assert putDocRes == "ok"

    // 4. Get verification
    let docContent = get(bucket, "consensus.txt")
    assert docContent == "This is an intelligence report on Raft consensus algorithms and distributed state replication."

    // 5. Test Time Travel Queries on the versioned bucket
    // Put version 1
    put(vbucket, "history.txt", "version 1 content")
    time.sleep(1200)
    let t1 = time.now()
    time.sleep(1200)

    // Put version 2
    put(vbucket, "history.txt", "version 2 content")
    
    // Query historical at t1
    let histV1 = at(vbucket, "history.txt", t1)
    assert histV1 == "version 1 content"

    // Query latest
    let histLatest = get(vbucket, "history.txt")
    assert histLatest == "version 2 content"

    // 6. Test Semantic Search
    // Wait a brief moment for background indexing to run
    time.sleep(1000)
    let searchResults = search(bucket, "consensus replication algorithms", 5)
    assert searchResults.length > 0
    assert searchResults[0].key == "consensus.txt"

    // 7. List Objects
    let objects = list(bucket, "")
    assert objects.length == 1
    assert objects[0].key == "consensus.txt"

    // 8. Clean up standard bucket objects
    assert deleteObject(bucket, "consensus.txt") == "ok"

    // 9. Clean up standard bucket
    assert deleteBucket(bucket) == "ok"

    // 10. Clean up versioned bucket objects (leaves delete markers, but we clean up anyway)
    deleteObject(vbucket, "history.txt")
}
