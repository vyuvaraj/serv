// Serv Standard Library: Multi-backend Storage Client
// Import: import { put, get, transform } from "stdlib/store.srv"

export fn put(key: string, val: any) {
    return store.put(key, val)
}

export fn get(key: string) -> any {
    return store.get(key)
}

export fn transform(inputKey: string, stages: any, outputKey: string, saveTrace: bool) {
    return store.transform(inputKey, stages, outputKey, saveTrace)
}
