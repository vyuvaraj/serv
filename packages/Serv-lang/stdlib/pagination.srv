// Serv Standard Library: Pagination Helpers
// Import: import { paginate, pageResponse } from "stdlib/pagination.srv"

// Calculate offset from page number and page size
export fn offset(page, pageSize) {
    if page < 1 {
        return 0
    }
    return (page - 1) * pageSize
}

// Build a pagination response envelope
export fn pageResponse(items, page, pageSize, totalCount) {
    let totalPages = totalCount / pageSize
    return {
        "items": items,
        "page": page,
        "pageSize": pageSize,
        "totalCount": totalCount,
        "totalPages": totalPages
    }
}

// Parse page/pageSize from request query params with defaults
export fn parsePageParams(req) {
    let page = 1
    let pageSize = 20
    if req.query.page != nil {
        page = req.query.page
    }
    if req.query.pageSize != nil {
        pageSize = req.query.pageSize
    }
    return { "page": page, "pageSize": pageSize }
}
