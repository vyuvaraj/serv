// Serv Example 02: REST API & HTTP Clients
// Run this example:
//   $env:PORT="8081"; .\serv.exe run examples/02_rest_api.srv
//
// Test it:
//   Invoke-RestMethod -Uri "http://localhost:8081/health"
//   Invoke-RestMethod -Method Post -Uri "http://localhost:8081/orders" -Body "{\"item\": \"coffee\"}"
//   Invoke-RestMethod -Uri "http://localhost:8081/metrics"

// Expose server on PORT env variable

server env("PORT")

// Expose GET healthcheck endpoint

route "GET" "/health" (req) {
    log.info("Checking API status...")
    return { "status": "ok", "time": time.now() }
}

// Expose POST orders endpoint

route "POST" "/orders" (req) {
    let body = req.body
    log.info("Received new order request: ", body)

    // Call external API using native HTTP client
    let postResponse = http.post("https://httpbin.org/post", body)

    // Record a custom metric counter
    metric.inc("orders_processed_total")

    return {
        "message": "Order processed successfully",
        "provider_status": postResponse.status
    }
}

// Expose GET test endpoint for query params and headers

route "GET" "/test-query-headers" (req) {
    let q = req.query.name
    let h = req.headers["x-test-header"]
    let p = req.params.name
    return { "query": q, "header": h, "param": p }
}
