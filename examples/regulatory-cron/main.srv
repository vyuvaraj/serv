// Regulatory Cron Service — Serv Port
// Equivalent of the Java regulatory-cron-service (145+ cron jobs, distributed locking, DLQ)
//
// Run: serv run examples/regulatory-cron/main.srv
// Build: serv build examples/regulatory-cron/main.srv -o cron-service.exe

import { JobConfiguration, RetryPolicy, ExecutionStatus, JobStatus, TriggerType } from "./models/domain.srv"
import { acquireLock, releaseLock, extendLock } from "./services/lock.srv"
import { executeWithRetry } from "./services/executor.srv"
import { createDlqEntry, listDlq, replayDlq } from "./services/dlq.srv"
import { emitAlert } from "./services/alert.srv"

server env("PORT")
database env("MONGODB_URI")

// --- Channels for job scheduling ---
let jobQueue = channel.new(200)

// --- Atomic counters for observability ---
atomic.new("running_jobs", 0)
atomic.new("total_executions", 0)
atomic.new("total_failures", 0)

// --- Scheduler: poll for due jobs every second ---
every 1s {
    let now = time.unix()
    let dueJobs, err = db.query("find", "jobs", f"{\"nextRunTime\": {\"$lte\": {now}}, \"status\": \"ACTIVE\", \"enabled\": true}")
    if err == nil {
        for job in dueJobs {
            channel.trySend(jobQueue, job)
        }
    }
}

// --- Worker pool: 5 concurrent job executors ---
spawn startWorker(1)
spawn startWorker(2)
spawn startWorker(3)
spawn startWorker(4)
spawn startWorker(5)

fn startWorker(workerId: int) {
    for true {
        let job = channel.receive(jobQueue)
        if job == nil {
            return nil
        }
        processJob(job, workerId)
    }
}

fn processJob(job, workerId: int) {
    let jobId = job.id
    let scheduledTime = job.nextRunTime

    // Acquire distributed lock
    let lock, err = acquireLock(jobId, scheduledTime)
    if err != nil {
        log.debug(f"Worker {workerId}: lock denied for job {jobId}")
        return nil
    }

    atomic.inc("running_jobs")
    log.info(f"Worker {workerId}: executing job {jobId}")

    // Execute with retry
    let result, execErr = executeWithRetry(job)

    // Update job state
    let nextTime = computeNextRun(job.cronExpression)
    db.upsert("jobs",
        f"{\"_id\": \"{jobId}\"}",
        f"{\"$set\": {\"lastRunTime\": {time.unix()}, \"nextRunTime\": {nextTime}, \"lastRunStatus\": \"{result}\"}}"
    )

    // Release lock
    releaseLock(lock)
    atomic.dec("running_jobs")
    atomic.inc("total_executions")

    if result == "FAILED" {
        atomic.inc("total_failures")
        emitAlert(jobId, job.name, execErr)
    }
}

fn computeNextRun(cronExpr: string) -> int {
    // Simplified: add 60 seconds. Real impl would parse cron expression.
    return time.unix() + 60
}

// --- Background sync: reconcile queue with DB every 60s ---
every 60s {
    log.debug("Background sync: reconciling job queue with database")
    let activeJobs, err = db.query("find", "jobs", "{\"enabled\": true, \"status\": \"ACTIVE\"}")
    if err == nil {
        log.debug(f"Sync complete: {activeJobs.length} active jobs")
    }
}

// --- DLQ cleanup: daily at 2 AM ---
cron "0 0 2 * * *" {
    log.info("Running DLQ cleanup...")
    let expired, err = db.query("find", "dlq", "{\"status\": \"REPLAYED\", \"createdAt\": {\"$lt\": ...}}")
    if err == nil {
        log.info(f"Purged {expired.length} expired DLQ entries")
    }
}

// --- REST API ---

middleware xActor(req) {
    // Extract actor from X-Actor header (passed by CCC proxy)
    log.with("actor", req.body, "path", req.path, "API request")
}

// List jobs (paginated)
route "GET" "/api/v1/jobs" (req) use [xActor] {
    let page = 0
    let result = db.queryPage("jobs", "{}", page, 20)
    return result
}

// Get single job
route "GET" "/api/v1/jobs/:id" (req) {
    let job = db.findOne("jobs", f"{\"_id\": \"{req.params.id}\"}")
    if job == nil {
        return { "error": "Job not found", "status": 404 }
    }
    return { "job": job }
}

// Create job
route "POST" "/api/v1/jobs" (req) use [xActor] {
    let body = json.parse(req.body)
    let result = db.query("insert", "jobs", req.body)
    return { "created": true, "id": result }
}

// Update job
route "PUT" "/api/v1/jobs/:id" (req) use [xActor] {
    let result = db.upsert("jobs",
        f"{\"_id\": \"{req.params.id}\"}",
        req.body
    )
    return result
}

// Delete job
route "DELETE" "/api/v1/jobs/:id" (req) use [xActor] {
    db.query("delete", "jobs", f"{\"_id\": \"{req.params.id}\"}")
    return { "deleted": true }
}

// Pause job
route "POST" "/api/v1/jobs/:id/pause" (req) use [xActor] {
    db.upsert("jobs",
        f"{\"_id\": \"{req.params.id}\"}",
        f"{\"$set\": {\"status\": \"PAUSED\", \"nextRunTime\": null}}"
    )
    return { "status": "paused" }
}

// Resume job
route "POST" "/api/v1/jobs/:id/resume" (req) use [xActor] {
    db.upsert("jobs",
        f"{\"_id\": \"{req.params.id}\"}",
        f"{\"$set\": {\"status\": \"ACTIVE\"}}"
    )
    return { "status": "resumed" }
}

// Manual trigger
route "POST" "/api/v1/jobs/:id/trigger" (req) use [xActor] {
    let job = db.findOne("jobs", f"{\"_id\": \"{req.params.id}\"}")
    if job == nil {
        return { "error": "Job not found" }
    }
    channel.send(jobQueue, job)
    return { "triggered": true, "queued": channel.len(jobQueue) }
}

// Execution history
route "GET" "/api/v1/jobs/:id/executions" (req) {
    let result = db.queryPage("executions", f"{\"jobId\": \"{req.params.id}\"}", 0, 20)
    return result
}

// DLQ endpoints
route "GET" "/api/v1/dlq" (req) {
    let result = listDlq(0, 20)
    return result
}

route "POST" "/api/v1/dlq/:id/replay" (req) {
    let execId = replayDlq(req.params.id, jobQueue)
    return { "executionId": execId }
}

// Bulk operations
route "POST" "/api/v1/jobs/bulk/pause" (req) use [xActor] {
    let body = json.parse(req.body)
    let jobs = db.query("find", "jobs", f"{\"status\": \"ACTIVE\"}")
    let count = 0
    for job in jobs {
        db.upsert("jobs", f"{\"_id\": \"{job.id}\"}", f"{\"$set\": {\"status\": \"PAUSED\"}}")
        count = count + 1
    }
    return { "affected": count }
}

route "POST" "/api/v1/jobs/bulk/resume" (req) use [xActor] {
    let jobs = db.query("find", "jobs", f"{\"status\": \"PAUSED\"}")
    let count = 0
    for job in jobs {
        db.upsert("jobs", f"{\"_id\": \"{job.id}\"}", f"{\"$set\": {\"status\": \"ACTIVE\"}}")
        count = count + 1
    }
    return { "affected": count }
}

// Observability
route "GET" "/api/v1/stats" (req) {
    return {
        "running_jobs": atomic.get("running_jobs"),
        "total_executions": atomic.get("total_executions"),
        "total_failures": atomic.get("total_failures"),
        "queue_depth": channel.len(jobQueue)
    }
}
