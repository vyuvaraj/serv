// Serv Example 51: AI Integration
// Supports: OpenAI, Anthropic, Ollama (local)
//
// Setup:
//   export OPENAI_API_KEY="sk-..."
//   serv run examples/51_ai_integration.srv
//
// Test:
//   curl -X POST http://localhost:8080/summarize -d "The quick brown fox..."
//   curl -X POST http://localhost:8080/chat -d "What is Serv?"

ai "openai://gpt-4o-mini"
// For local Ollama: ai "ollama://localhost:11434/llama3"
// For Anthropic:    ai "anthropic://claude-3-haiku-20240307"

server "8080"

route "POST" "/summarize" (req) {
    let summary = ai.complete({
        "prompt": f"Summarize this in one sentence: {req.body}",
        "max_tokens": 100
    })
    return { "summary": summary }
}

route "POST" "/chat" (req) {
    let reply = ai.complete(req.body)
    return { "reply": reply }
}

route "POST" "/embed" (req) {
    let vector = ai.embed(req.body)
    return { "embedding": vector }
}
