{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Serv",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-declarations"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.srv",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.srv",
          "begin": "f?\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.srv",
              "match": "\\\\."
            },
            {
              "name": "meta.embedded.line.srv",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.srv",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.srv",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.srv",
          "match": "\\b(try|catch|match|every|cron|route|publish|subscribe|spawn|extern|from|test|assert)\\b"
        },
        {
          "name": "keyword.declaration.srv",
          "match": "\\b(fn|let|server|broker|database|cache)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.srv",
          "match": "\\b(log\\.(info|warn|error)|metric\\.inc|db\\.query|cache\\.(set|get)|json\\.(parse|stringify)|http\\.(get|post)|time\\.now|env|config)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.srv",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.srv",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.srv",
          "match": "=>|="
        },
        {
          "name": "keyword.operator.arithmetic.srv",
          "match": "\\+|\\-|\\*|/"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.srv",
          "match": "\\b\\d+(\\.\\d+)?([smh])?\\b"
        }
      ]
    },
    "function-declarations": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.srv"
            },
            "2": {
              "name": "entity.name.function.srv"
            }
          }
        }
      ]
    }
  },
  "scopeName": "source.srv"
}
