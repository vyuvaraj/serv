{
  "name": "serv-vscode",
  "displayName": "Serv Language Support",
  "description": "Full language support for the Serv programming language (.srv files) — syntax highlighting, diagnostics, autocomplete, hover, go-to-definition, and LSP.",
  "version": "3.0.0",
  "publisher": "vyuvaraj",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:serv",
    "onCommand:serv.run",
    "onCommand:serv.build",
    "onCommand:serv.test",
    "onCommand:serv.watch"
  ],
  "main": "./extension.js",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vyuvaraj/Serv-lang"
  },
  "author": "Yuvaraj",
  "keywords": [
    "serv",
    "srv",
    "background services",
    "microservices",
    "scheduler",
    "dsl",
    "syntax highlighting",
    "snippets",
    "lsp",
    "go"
  ],
  "homepage": "https://github.com/vyuvaraj/Serv-lang",
  "contributes": {
    "languages": [
      {
        "id": "serv",
        "aliases": [
          "Serv",
          "serv"
        ],
        "extensions": [
          ".srv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "serv",
        "scopeName": "source.srv",
        "path": "./syntaxes/serv.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "serv",
        "path": "./snippets/serv.code-snippets"
      }
    ],
    "configuration": {
      "title": "Serv",
      "properties": {
        "serv.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the serv-lsp binary. If empty, looks for 'serv-lsp' in PATH or workspace root."
        },
        "serv.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the serv compiler binary. If empty, looks for 'serv' or 'serv.exe' in workspace root or PATH."
        }
      }
    },
    "commands": [
      {
        "command": "serv.run",
        "title": "Serv: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "serv.build",
        "title": "Serv: Build Current File",
        "icon": "$(package)"
      },
      {
        "command": "serv.test",
        "title": "Serv: Test Current File",
        "icon": "$(beaker)"
      },
      {
        "command": "serv.watch",
        "title": "Serv: Run in Watch Mode",
        "icon": "$(eye)"
      }
    ],
    "keybindings": [
      {
        "command": "serv.run",
        "key": "ctrl+shift+r",
        "when": "editorLangId == serv"
      },
      {
        "command": "serv.build",
        "key": "ctrl+shift+b",
        "when": "editorLangId == serv"
      },
      {
        "command": "serv.test",
        "key": "ctrl+shift+t",
        "when": "editorLangId == serv"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "serv.run",
          "when": "editorLangId == serv",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vyuvaraj/Serv-lang/issues"
  }
}
