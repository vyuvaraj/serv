{
  "name": "serv-vscode",
  "displayName": "Serv Programming Language Support",
  "description": "Full language support for the Serv programming language (.srv files) — syntax highlighting, diagnostics, autocomplete, hover, go-to-definition, and LSP.",
  "version": "3.1.0",
  "publisher": "vyuvaraj",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Formatters"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:serv"
  ],
  "main": "./extension.js",
  "icon": "images/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vyuvaraj/Serv-lang"
  },
  "author": "Yuvaraj",
  "keywords": [
    "serv",
    "srv",
    "background services",
    "microservices",
    "scheduler",
    "dsl",
    "syntax highlighting",
    "snippets",
    "lsp",
    "go"
  ],
  "homepage": "https://github.com/vyuvaraj/Serv-lang",
  "contributes": {
    "languages": [
      {
        "id": "serv",
        "aliases": [
          "Serv",
          "serv"
        ],
        "extensions": [
          ".srv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "serv",
        "scopeName": "source.srv",
        "path": "./syntaxes/serv.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "serv",
        "path": "./snippets/serv.code-snippets"
      }
    ],
    "configuration": {
      "title": "Serv",
      "properties": {
        "serv.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the serv-lsp binary. If empty, looks for 'serv-lsp' in PATH or workspace root."
        },
        "serv.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the serv compiler binary. If empty, looks for 'serv' or 'serv.exe' in workspace root or PATH."
        },
        "serv.enableInlayHints": {
          "type": "boolean",
          "default": true,
          "description": "Show inferred return type and variable type hints inline in the editor."
        },
        "serv.registryUrl": {
          "type": "string",
          "default": "http://localhost:8090/api/registry/services",
          "description": "The URL of the ServRegistry microservice to fetch health statuses for the ServVerse services sidebar panel."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "serv-services",
          "title": "ServVerse",
          "icon": "images/serv-panel.svg"
        }
      ]
    },
    "views": {
      "serv-services": [
        {
          "id": "serv-services-panel",
          "name": "Services",
          "type": "webview"
        }
      ],
      "explorer": [
        {
          "id": "serv-test-explorer",
          "name": "Serv Tests",
          "when": "workspaceContains:**/*.srv"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "serv.refreshServices",
          "when": "view == serv-services-panel",
          "group": "navigation"
        }
      ]
    },
    "commands": [
      {
        "command": "serv.run",
        "title": "Serv: Run Current File",
        "icon": "$(play)"
      },
      {
        "command": "serv.build",
        "title": "Serv: Build Current File",
        "icon": "$(package)"
      },
      {
        "command": "serv.test",
        "title": "Serv: Test Current File",
        "icon": "$(beaker)"
      },
      {
        "command": "serv.watch",
        "title": "Serv: Run in Watch Mode",
        "icon": "$(eye)"
      },
      {
        "command": "serv.visualizeWorkflow",
        "title": "Serv: Visualize DAG Workflow"
      },
      {
        "command": "serv.exploreQueue",
        "title": "Serv: Explore Queue Broker"
      },
      {
        "command": "serv.exploreStore",
        "title": "Serv: Explore Store Buckets"
      },
      {
        "command": "serv.exploreLocks",
        "title": "Serv: Inspect Distributed Locks"
      },
      {
        "command": "serv.simulateRoute",
        "title": "Serv: Simulate Route Gateway"
      },
      {
        "command": "serv.exploreCron",
        "title": "Serv: Inspect Cron Jobs"
      },
      {
        "command": "serv.inspectCache",
        "title": "Serv: Inspect Cache Stats"
      },
      {
        "command": "serv.inspectAuth",
        "title": "Serv: Inspect Progressive Auth"
      },
      {
        "command": "serv.openREPL",
        "title": "Serv: Launch Interactive REPL"
      },
      {
        "command": "serv.viewMesh",
        "title": "Serv: View Service Mesh Topology"
      },
      {
        "command": "serv.traceRequests",
        "title": "Serv: Trace Distributed Requests"
      },
      {
        "command": "serv.viewRegistry",
        "title": "Serv: View Service Registry Health"
      },
      {
        "command": "serv.runBench",
        "title": "Serv: Benchmark Current File"
      },
      {
        "command": "serv.viewDeployments",
        "title": "Serv: View Cloud Deployments"
      },
      {
        "command": "serv.inspectPool",
        "title": "Serv: Inspect Connection Pool"
      },
      {
        "command": "serv.inspectMail",
        "title": "Serv: Inspect Mail Queue"
      },
      {
        "command": "serv.refreshTests",
        "title": "Serv: Refresh Test Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "serv.runTestsWithGutter",
        "title": "Serv: Run Tests (with Gutter Decorations)",
        "icon": "$(beaker)"
      },
      {
        "command": "serv.clearTestDecorations",
        "title": "Serv: Clear Test Gutter Markers"
      },
      {
        "command": "serv.viewTunnels",
        "title": "Serv: View Tunnel Sessions"
      },
      {
        "command": "serv.refreshServices",
        "title": "Serv: Refresh Services Panel",
        "icon": "$(refresh)"
      },
      {
        "command": "serv.organizeImports",
        "title": "Serv: Add Missing Imports"
      },
      {
        "command": "serv.initProject",
        "title": "Serv: New Project from Template"
      },
      {
        "command": "serv.deploy",
        "title": "Serv: Deploy to ServCloud"
      },
      {
        "command": "serv.runCoverage",
        "title": "Serv: Run Tests with Coverage Highlights"
      },
      {
        "command": "serv.clearCoverage",
        "title": "Serv: Clear Coverage Highlights"
      },
      {
        "command": "serv.openPlayground",
        "title": "Serv: Open Web Playground"
      }
    ],
    "keybindings": [
      {
        "command": "serv.run",
        "key": "ctrl+shift+r",
        "when": "editorLangId == serv"
      },
      {
        "command": "serv.build",
        "key": "ctrl+shift+b",
        "when": "editorLangId == serv"
      },
      {
        "command": "serv.test",
        "key": "ctrl+shift+t",
        "when": "editorLangId == serv"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "serv.run",
          "when": "editorLangId == serv",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/vyuvaraj/Serv-lang/issues"
  }
}
